#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute aptos"
set -euo pipefail

VERSION="${APTOS_TEST_VERSION:-9.2.0}"

mise plugin link --force aptos .
mise cache clear
mise install "aptos@${VERSION}"

output=$(mise exec "aptos@${VERSION}" -- aptos --version)
echo "aptos output: $output"

if echo "$output" | grep -q "aptos ${VERSION}"; then
    echo "✓ Tests passed"
else
    echo "✗ Test failed: expected 'aptos ${VERSION}' in output"
    exit 1
fi
